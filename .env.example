# ── Supabase (your NEW project) ─────────────────────────────────────
# Project: oyhcchumlizmhwvjjlrl
NEXT_PUBLIC_SUPABASE_URL=https://oyhcchumlizmhwvjjlrl.supabase.co
# Service-role key (Settings → API → service_role). SERVER-ONLY — never
# expose to the browser. All screener DB access is server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Market data provider ────────────────────────────────────────────
# 'fmp' for live data, 'mock' for a zero-key demo (deterministic fixtures).
MARKET_DATA_PROVIDER=mock
# Free key from https://financialmodelingprep.com (only needed for 'fmp').
MARKET_DATA_FMP_API_KEY=

# ── Cron (optional) ─────────────────────────────────────────────────
# If set, /api/ingest requires Authorization: Bearer <CRON_SECRET>.
# Leave blank to keep the endpoint open (fine for a free app).
CRON_SECRET=
